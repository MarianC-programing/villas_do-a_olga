# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env al repositorio

# PostgreSQL — Neon serverless
# Obtener en: https://console.neon.tech → tu proyecto → Connection string
DATABASE_URL="postgresql://usuario:password@host/neondb?sslmode=require&channel_binding=require"

# Token de administrador para GET /api/contact-submissions
# Generar con: openssl rand -hex 32
ADMIN_TOKEN=""
